# CHPP OAuth 1.0a credentials (from hattrick.org/en/community/CHPP/checkAccess.aspx)
CHPP_CONSUMER_KEY=your_consumer_key_here
CHPP_CONSUMER_SECRET=your_consumer_secret_here

# JWT secret for signing session tokens
JWT_SECRET=change_this_to_a_long_random_string_in_production

# Callback URL after user authorizes on Hattrick
# In dev: http://localhost:3000/auth/callback
# In prod: https://your-railway-app.up.railway.app/auth/callback
CHPP_CALLBACK_URL=http://localhost:3000/auth/callback

# Frontend URL (for CORS and post-auth redirect)
FRONTEND_URL=http://localhost:5173

# Server port
PORT=3000

# Node environment
NODE_ENV=development
