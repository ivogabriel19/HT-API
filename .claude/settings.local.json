{
  "permissions": {
    "allow": [
      "Bash(npm install *)",
      "Bash(node src/index.js)",
      "Bash(curl -s http://localhost:3000/health)",
      "Bash(curl -s http://localhost:3000/auth/me)",
      "Bash(curl -s -X POST http://localhost:3000/auth/logout)",
      "Bash(curl -s http://localhost:3000/api/stadium/analysis)",
      "Bash(curl -sv http://localhost:3000/auth/login)",
      "Bash(netstat -ano)",
      "Bash(tasklist /FI \"PID eq 1960\" /FO LIST)",
      "Bash(powershell -Command \"Get-Process -Id 1960 | Select-Object Name, Id, MainWindowTitle\")",
      "Bash(powershell -Command \"Get-Process -Id 1960 | Select-Object Name, Id, CommandLine\")",
      "Bash(powershell -Command \"\\(Get-WmiObject Win32_Process -Filter 'ProcessId=1960'\\).CommandLine\")",
      "Bash(powershell -Command \"Stop-Process -Id 1960 -Force\")"
    ]
  }
}
